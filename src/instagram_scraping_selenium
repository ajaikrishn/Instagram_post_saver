from selenium import webdriver
from selenium.webdriver.firefox.service import Service
from selenium.webdriver.firefox.options import Options
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from getpass import getpass
from bs4 import BeautifulSoup
import time

# -----------------------------
# Configuration
# -----------------------------
GECKODRIVER_PATH = "/home/ajai-krishna/setups/geckodriver-v0.36.0-linux64/"
TARGET_URL = "https://www.instagram.com/"

# -----------------------------
# Read credentials
# -----------------------------
username = input("Instagram Username: ")
password = getpass("Instagram Password: ")

# -----------------------------
# Firefox setup
# -----------------------------
options = Options()
# options.add_argument("--headless")  # Uncomment if desired

driver = webdriver.Firefox(
    service=Service(GECKODRIVER_PATH),
    options=options
)

wait = WebDriverWait(driver, 30)

try:
    # Open Instagram login page
    driver.get(TARGET_URL)

    # Accept cookies if prompted (optional)
    try:
        cookie_btn = WebDriverWait(driver, 5).until(
            EC.element_to_be_clickable(
                (By.XPATH, "//button[contains(., 'Allow all cookies') or contains(., 'Accept')]")
            )
        )
        cookie_btn.click()
    except:
        pass

    # Wait for login form
    user_box = wait.until(
        EC.presence_of_element_located((By.NAME, "username"))
    )

    pass_box = driver.find_element(By.NAME, "password")

    # Enter credentials
    user_box.clear()
    user_box.send_keys(username)

    pass_box.clear()
    pass_box.send_keys(password)

    # Click Login
    login_btn = driver.find_element(
        By.XPATH,
        "//button[@type='submit']"
    )
    login_btn.click()

    # Wait for login to complete
    time.sleep(10)

    print("Current URL:", driver.current_url)

    # Navigate to any page after login
    target_post = "https://www.instagram.com/p/DaOU3EnEf_3/"
    driver.get(target_post)

    time.sleep(5)

    soup = BeautifulSoup(driver.page_source, "html.parser")

    print(soup.title)

finally:
    input("\nPress Enter to close browser...")
    driver.quit()